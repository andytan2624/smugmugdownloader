# ── SmugMug API credentials ──────────────────────────────────────────────────
# 1. Go to: https://www.smugmug.com/api/developer/apply
# 2. Fill in the form — choose "Desktop Application" for Application Type
# 3. You'll receive an API Key and API Secret; paste them below

SMUGMUG_API_KEY=your_api_key_here
SMUGMUG_API_SECRET=your_api_secret_here

# After running `python main.py auth`, paste the tokens printed to the terminal:
SMUGMUG_ACCESS_TOKEN=
SMUGMUG_ACCESS_SECRET=
